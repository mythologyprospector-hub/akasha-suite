#!/data/data/com.termux/files/usr/bin/bash
set -e

echo "=================================="
echo "           AKASHA RUN"
echo "=================================="

if [ -d ~/akasha-discovery ]; then
  cd ~/akasha-discovery
elif [ -d "$(cd -- "$(dirname -- "$0")/../../akasha-discovery" && pwd 2>/dev/null)" ]; then
  cd "$(cd -- "$(dirname -- "$0")/../../akasha-discovery" && pwd)"
else
  echo "Could not find akasha-discovery in ~/ or beside akasha-suite"
  exit 1
fi

python run_discovery.py "$@"
