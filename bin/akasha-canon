#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

MODE="${1:-check}"

VALID_MODES=(
  "check"
  "fix"
  "patch"
  "write"
  "classify"
  "topology"
  "doctor"
  "enforce"
  "enforce-manifest"
  "enforce-readme"
)

is_valid_mode=0
for m in "${VALID_MODES[@]}"; do
  if [[ "$MODE" == "$m" ]]; then
    is_valid_mode=1
    break
  fi
done

if [[ "$is_valid_mode" -ne 1 ]]; then
  echo "Usage: akasha-canon [check|fix|patch|write|classify|topology|doctor|enforce|enforce-manifest|enforce-readme]"
  exit 1
fi

echo "=================================="
echo "         AKASHA CANON"
echo "=================================="
echo "Mode: $MODE"
echo

README_SECTIONS=(
  "## Engine Role"
  "## Why it exists"
  "## Inputs"
  "## Memory / Registry"
  "## Relation Model"
  "## Evaluator"
  "## Outputs"
  "## Position in Constellation"
  "## Next Steps"
)

MANIFEST_KEYS=(
  "repo:"
  "engine:"
  "identity:"
  "ownership:"
  "interfaces:"
  "capabilities:"
  "alignment:"
  "depends_on:"
)

LEGACY_TOP_KEYS=(
  "name:"
  "type:"
  "generated_by:"
  "domain:"
)

ENGINE_FAMILY="unknown"
ENGINE_CLASS="unknown"
ENGINE_ROLE="unknown"
IDENTITY_LAYER="unknown"
DESCRIPTION_TEXT=""
DEPENDS_ON=()
CONSUMES=()
PRODUCES=()
CAPABILITIES=()

readme_missing_sections() {
  local f="$1"
  local missing=0

  for section in "${README_SECTIONS[@]}"; do
    if ! grep -Fq "$section" "$f"; then
      echo "    Missing README section: $section"
      missing=1
    fi
  done

  return $missing
}

manifest_missing_keys() {
  local f="$1"
  local missing=0

  for key in "${MANIFEST_KEYS[@]}"; do
    if ! grep -Fq "$key" "$f"; then
      echo "    Missing manifest key: $key"
      missing=1
    fi
  done

  return $missing
}

doctor_manifest() {
  local repo="$1"
  local file="$2"
  local issues=0

  for legacy in "${LEGACY_TOP_KEYS[@]}"; do
    if grep -Eq "^${legacy}" "$file"; then
      echo "    Legacy top-level key present: ${legacy}"
      issues=1
    fi
  done

  if grep -Eq '^[[:space:]]*family:[[:space:]]*unknown[[:space:]]*$' "$file"; then
    echo "    Unknown engine family"
    issues=1
  fi

  if grep -Eq '^[[:space:]]*class:[[:space:]]*unknown[[:space:]]*$' "$file"; then
    echo "    Unknown engine class"
    issues=1
  fi

  if grep -Eq '^[[:space:]]*role:[[:space:]]*unknown[[:space:]]*$' "$file"; then
    echo "    Unknown engine role"
    issues=1
  fi

  if grep -Eq '^[[:space:]]*layer:[[:space:]]*unknown[[:space:]]*$' "$file"; then
    echo "    Unknown identity layer"
    issues=1
  fi

  if grep -Fq "Canonical Akasha repo placeholder. Replace with repo-specific description." "$file"; then
    echo "    Placeholder description present"
    issues=1
  fi

  local dep_block
  dep_block="$(awk '
    /^depends_on:/ {flag=1; next}
    flag && /^[^[:space:]-]/ {flag=0}
    flag {print}
  ' "$file" || true)"

  if echo "$dep_block" | grep -Fq "$repo"; then
    echo "    Self dependency detected"
    issues=1
  fi

  if [[ "$repo" == "akasha-time-nexus" ]]; then
    if echo "$dep_block" | grep -Fq "akasha-events"; then
      echo "    Suspicious dependency: akasha-time-nexus should not depend on akasha-events"
      issues=1
    fi
  fi

  return $issues
}

patch_readme() {
  local f="$1"

  for section in "${README_SECTIONS[@]}"; do
    if ! grep -Fq "$section" "$f"; then
      echo >> "$f"
      echo "$section" >> "$f"
      echo >> "$f"
      echo "TODO: fill this section." >> "$f"
      echo "  -> appended README section: $section"
    fi
  done
}

manifest_block_for_key() {
  local key="$1"
  local repo="$2"

  case "$key" in
    "repo:")
      cat <<EOT
repo:
  name: ${repo}
  ecosystem: akasha
  version: 0.1.0
  status: active
EOT
      ;;
    "engine:")
      cat <<'EOT'
engine:
  family: unknown
  class: unknown
  role: unknown
EOT
      ;;
    "identity:")
      cat <<'EOT'
identity:
  role: engine
  layer: unknown
  description: >
    Canonical Akasha repo placeholder. Replace with repo-specific description.
EOT
      ;;
    "ownership:")
      cat <<'EOT'
ownership:
  steward: human
  approval_required: true
EOT
      ;;
    "interfaces:")
      cat <<'EOT'
interfaces:
  consumes: []
  produces: []
EOT
      ;;
    "capabilities:")
      cat <<'EOT'
capabilities: []
EOT
      ;;
    "alignment:")
      cat <<'EOT'
alignment:
  axioms_required: true
  canonical_structure: true
  interpretation_free_core: true
EOT
      ;;
    "depends_on:")
      cat <<'EOT'
depends_on: []
EOT
      ;;
  esac
}

patch_manifest() {
  local f="$1"
  local repo="$2"

  for key in "${MANIFEST_KEYS[@]}"; do
    if ! grep -Fq "$key" "$f"; then
      echo >> "$f"
      manifest_block_for_key "$key" "$repo" >> "$f"
      echo "  -> appended manifest block: $key"
    fi
  done
}

