#!/usr/bin/env bash

MODE="${1:-check}"

HOME_DIR="$HOME"

print_header() {
echo "=================================="
echo "         AKASHA CANON"
echo "=================================="
echo "Mode: $MODE"
echo ""
}

check_manifest_keys() {

manifest="$1"

missing=0

keys=(
engine
identity
ownership
interfaces
capabilities
alignment
depends_on
)

for k in "${keys[@]}"; do
    if ! grep -q "^$k:" "$manifest" 2>/dev/null; then
        echo "    Missing manifest key: $k"
        missing=1
    fi
done

return $missing
}

check_repo() {

repo="$1"
name=$(basename "$repo")

echo "Repo: $name"

canon_ok=1

if [ -f "$repo/README.md" ]; then
    echo "  README.md: present"
else
    echo "  README.md: MISSING"
    canon_ok=0
fi

if [ -f "$repo/repo-manifest.yaml" ]; then
    echo "  repo-manifest.yaml: present"

    if ! check_manifest_keys "$repo/repo-manifest.yaml"; then
        canon_ok=0
    fi

else
    echo "  repo-manifest.yaml: MISSING"
    canon_ok=0
fi

if [ -f "$repo/.gitignore" ]; then
    echo "  .gitignore: present"

    if grep -q "AKASHA_CANON_GUARD" "$repo/.gitignore" 2>/dev/null; then
        echo "  Guard: OK"
    else
        echo "  Guard: MISSING"
        canon_ok=0
    fi

else
    echo "  .gitignore: MISSING"
    canon_ok=0
fi

if [ "$canon_ok" -eq 1 ]; then
    echo "  Canon: OK"
else
    echo "  Canon: CHECK"
fi

echo ""

}

run_checks() {

found=0

for d in "$HOME_DIR"/akasha-*; do
    if [ -d "$d/.git" ]; then
        check_repo "$d"
        found=1
    fi
done

if [ "$found" -eq 0 ]; then
    echo "No Akasha repos found."
fi

}

print_header

if [ "$MODE" = "check" ]; then
    run_checks
else
    echo "Unknown mode."
fi
