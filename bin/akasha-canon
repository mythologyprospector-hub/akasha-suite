      CONSUMES=("ontology_models" "graph_phase_models" "foundational_discovery_inputs")
      PRODUCES=("discovery_primitives" "reusable_discovery_logic" "core_candidate_generation_outputs")
      CAPABILITIES=("foundational_discovery_modeling" "reusable_candidate_generation" "discovery_logic_structuring" "cross_engine_discovery_support")
      ;;
    akasha-engine)
      ENGINE_FAMILY="discovery"
      ENGINE_CLASS="discovery_engine"
      ENGINE_ROLE="engine_subsystem_coordination"
      IDENTITY_LAYER="coordination"
      DESCRIPTION_TEXT="Central engine coordination layer for the Akasha constellation. Responsible for orchestrating discovery-oriented subsystems."
      DEPENDS_ON=("akasha-discovery" "akasha-graph-phases" "akasha-ontology")
      CONSUMES=("discovery_candidates" "graph_phase_models" "ontology_models" "event_records")
      PRODUCES=("coordinated_engine_outputs" "routed_intermediate_artifacts" "engine_level_results")
      CAPABILITIES=("subsystem_coordination" "discovery_routing" "engine_orchestration" "intermediate_artifact_management")
      ;;
    akasha-forge)
      ENGINE_FAMILY="discovery"
      ENGINE_CLASS="discovery_engine"
      ENGINE_ROLE="artifact_and_structure_forging"
      IDENTITY_LAYER="construction"
      DESCRIPTION_TEXT="Forge engine for the Akasha constellation. Responsible for shaping candidate structures and discovery outputs into usable artifacts."
      DEPENDS_ON=("akasha-discovery" "akasha-graph-phases")
      CONSUMES=("discovery_candidates" "structure_proposals" "graph_models" "construction_inputs")
      PRODUCES=("forged_artifacts" "constructed_bundles" "shaped_outputs")
      CAPABILITIES=("artifact_forging" "bundle_construction" "candidate_shaping" "discovery_output_materialization")
      ;;
    akasha-constellation)
      ENGINE_FAMILY="meta"
      ENGINE_CLASS="coordination_engine"
      ENGINE_ROLE="constellation_state_coordination"
      IDENTITY_LAYER="coordination"
      DESCRIPTION_TEXT="Constellation coordination engine for the Akasha ecosystem. Responsible for relating major engines and tracking their place in the wider architecture."
      DEPENDS_ON=("akasha-grand-atlas" "akasha-events" "akasha-attractor" "akasha-prospector")
      CONSUMES=("repo_manifests" "engine_outputs" "topology_information" "coordination_inputs")
      PRODUCES=("constellation_maps" "coordination_views" "engine_relationship_models" "ecosystem_state_outputs")
      CAPABILITIES=("constellation_mapping" "ecosystem_coordination" "engine_relationship_tracking" "topology_view_generation")
      ;;
    akasha-suite)
      ENGINE_FAMILY="meta"
      ENGINE_CLASS="coordination_engine"
      ENGINE_ROLE="constellation_governance"
      IDENTITY_LAYER="coordination"
      DESCRIPTION_TEXT="Coordination and tooling layer for the Akasha constellation. Responsible for canonical utilities, synchronization helpers, and repo health tools."
      DEPENDS_ON=("akasha-grand-atlas" "akasha-events" "akasha-attractor" "akasha-prospector")
      CONSUMES=("repo_states" "manifest_files" "documentation_states" "sync_targets")
      PRODUCES=("repo_health_reports" "canon_outputs" "sync_reports" "governance_artifacts")
      CAPABILITIES=("constellation_governance" "repo_health_checking" "synchronization_support" "canon_enforcement")
      ;;
    akasha-domain-*)
      ENGINE_FAMILY="domain"
      ENGINE_CLASS="domain_sidecar"
      ENGINE_ROLE="domain_specific_knowledge"
      IDENTITY_LAYER="domain"
      local domain_name="${repo#akasha-domain-}"
      DESCRIPTION_TEXT="${domain_name^} domain sidecar for the Akasha constellation. Responsible for carrying domain-specific structures and knowledge that enrich the wider system."
      DEPENDS_ON=("akasha-ontology")
      CONSUMES=("${domain_name}_inputs" "ontology_models" "domain_specific_records")
      PRODUCES=("${domain_name}_domain_models" "domain_enrichment_outputs")
      CAPABILITIES=("domain_specific_modeling" "domain_enrichment" "sidecar_knowledge_support")
      ;;
    akasha-visualize)
      ENGINE_FAMILY="presentation"
      ENGINE_CLASS="visualization_engine"
      ENGINE_ROLE="structure_and_output_rendering"
      IDENTITY_LAYER="presentation"
      DESCRIPTION_TEXT="Visualization layer for the Akasha constellation. Responsible for rendering structures, outputs, relationships, and interpreted views."
      DEPENDS_ON=("akasha-constellation" "akasha-world")
      CONSUMES=("akasha-constellation_outputs" "akasha-world_outputs" "akasha-events" "akasha-attractor" "akasha-prospector")
      PRODUCES=("rendered_views" "diagrams" "visual_reports" "structured_presentations")
      CAPABILITIES=("structure_rendering" "graph_visualization" "output_presentation" "report_visualization")
      ;;
    *)
      ENGINE_FAMILY="unknown"
      ENGINE_CLASS="unknown"
      ENGINE_ROLE="unknown"
      IDENTITY_LAYER="unknown"
      DESCRIPTION_TEXT="Canonical Akasha repo placeholder. Replace with repo-specific description."
      DEPENDS_ON=()
      CONSUMES=()
      PRODUCES=()
      CAPABILITIES=()
      ;;
  esac
}

yaml_list_block() {
  local indent="$1"
  shift
  local arr=("$@")

  if [[ "${#arr[@]}" -eq 0 ]]; then
    echo "${indent}[]"
    return
  fi

  echo
  for item in "${arr[@]}"; do
    echo "${indent}- ${item}"
  done
}

render_manifest() {
  local repo="$1"

  cat <<EOT
repo:
  name: ${repo}
  ecosystem: akasha
  version: 0.1.0
  status: active

engine:
  family: ${ENGINE_FAMILY}
  class: ${ENGINE_CLASS}
  role: ${ENGINE_ROLE}

identity:
  role: engine
  layer: ${IDENTITY_LAYER}
  description: >
    ${DESCRIPTION_TEXT}

ownership:
  steward: human
  approval_required: true

interfaces:
  consumes:$(yaml_list_block "    " "${CONSUMES[@]}")
  produces:$(yaml_list_block "    " "${PRODUCES[@]}")

capabilities:$(yaml_list_block "  " "${CAPABILITIES[@]}")

alignment:
  axioms_required: true
  canonical_structure: true
  interpretation_free_core: true

EOT

  if [[ "${#DEPENDS_ON[@]}" -eq 0 ]]; then
    echo "depends_on: []"
  else
    echo "depends_on:"
    for dep in "${DEPENDS_ON[@]}"; do
      echo "  - ${dep}"
    done
  fi
}

render_readme() {
  local repo="$1"

  cat <<EOT
# ${repo}

## Engine Role

${repo} is an Akasha engine in the **${ENGINE_FAMILY} / ${ENGINE_CLASS}** family and serves the role of **${ENGINE_ROLE}**.

## Why it exists

This repo exists so the Akasha constellation can perform its role in a disciplined and reusable way without forcing that responsibility into other repos.

## Inputs

Main inputs include:

EOT

  if [[ "${#CONSUMES[@]}" -eq 0 ]]; then
    echo "- none yet defined"
  else
    for item in "${CONSUMES[@]}"; do
      echo "- ${item}"
    done
  fi

  cat <<'EOT'

## Memory / Registry

This repo may maintain local structures, bundles, intermediate results, or domain records relevant to its engine role.

## Relation Model

This repo participates in the wider Akasha constellation by consuming structured inputs and producing outputs that can be linked into other engines and domains.

## Evaluator

This repo should evaluate its own outputs according to canonical structure, internal consistency, and fitness for downstream use.

## Outputs

Main outputs include:

EOT

  if [[ "${#PRODUCES[@]}" -eq 0 ]]; then
    echo "- none yet defined"
  else
    for item in "${PRODUCES[@]}"; do
      echo "- ${item}"
    done
  fi

  cat <<'EOT'

## Position in Constellation

This repo occupies a defined role in Akasha and should remain canonically aligned with the wider ecosystem.

## Next Steps

Immediate next steps:

- refine repo-specific implementation details
- strengthen internal documentation
- improve downstream and upstream integration
- keep this repo aligned with canon law
EOT
}

set_yaml_scalar_if_unknown() {
  local file="$1"
  local key="$2"
  local value="$3"

  python3 - "$file" "$key" "$value" <<'PY'
import sys
from pathlib import Path

file_path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]

text = file_path.read_text(encoding="utf-8")
lines = text.splitlines()

changed = False
for i, line in enumerate(lines):
    stripped = line.strip()
    if stripped.startswith(f"{key}:"):
        current = stripped.split(":", 1)[1].strip()
        if current in {"unknown", "[]", '""', "''"}:
            indent = line[:len(line) - len(line.lstrip())]
            lines[i] = f"{indent}{key}: {value}"
            changed = True
        break

if changed:
    file_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    print(f"  -> classified {key}: {value}")
PY
}

set_depends_if_empty() {
  local file="$1"
  shift
  local deps=("$@")

  python3 - "$file" "${deps[@]}" <<'PY'
import sys
from pathlib import Path

file_path = Path(sys.argv[1])
deps = list(sys.argv[2:])

text = file_path.read_text(encoding="utf-8")
lines = text.splitlines()

for i, line in enumerate(lines):
    stripped = line.strip()
    if stripped.startswith("depends_on:"):
        current = stripped.split(":", 1)[1].strip()
        if current == "[]":
            indent = line[:len(line) - len(line.lstrip())]
            block = [f"{indent}depends_on:"]
            for dep in deps:
                block.append(f"{indent}  - {dep}")
            if not deps:
                block = [f"{indent}depends_on: []"]
            lines[i:i+1] = block
            file_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
            if deps:
                print("  -> inferred depends_on: " + ", ".join(deps))
            else:
                print("  -> inferred depends_on: []")
        break
PY
}

for d in ~/akasha-* ~/engine-* ~/mythology-* ~/node-*; do
  [ -d "$d/.git" ] || continue

  repo="$(basename "$d")"
  readme="$d/README.md"
  manifest="$d/repo-manifest.yaml"

  echo "Repo: $repo"

  readme_ok=1
  manifest_ok=1

  if [ ! -f "$readme" ]; then
    echo "  README.md: MISSING"
    readme_ok=0
  else
    echo "  README.md: present"
    if ! readme_missing_sections "$readme"; then
      readme_ok=0
    fi
  fi

  if [ ! -f "$manifest" ]; then
    echo "  repo-manifest.yaml: MISSING"
    manifest_ok=0
  else
    echo "  repo-manifest.yaml: present"
    if ! manifest_missing_keys "$manifest"; then
      manifest_ok=0
    fi
  fi

  if [[ "$MODE" == "fix" ]]; then
    if [ ! -f "$readme" ]; then
      classify_repo "$repo"
      render_readme "$repo" > "$readme"
      echo "  -> created README.md"
    fi
    if [ ! -f "$manifest" ]; then
      classify_repo "$repo"
      render_manifest "$repo" > "$manifest"
      echo "  -> created repo-manifest.yaml"
    fi
  fi

  if [[ "$MODE" == "patch" ]]; then
    if [ ! -f "$readme" ]; then
      classify_repo "$repo"
      render_readme "$repo" > "$readme"
      echo "  -> created README.md"
    else
      patch_readme "$readme"
    fi

    if [ ! -f "$manifest" ]; then
      classify_repo "$repo"
      render_manifest "$repo" > "$manifest"
      echo "  -> created repo-manifest.yaml"
    else
      patch_manifest "$manifest" "$repo"
    fi
  fi

  if [[ "$MODE" == "write" ]]; then
    classify_repo "$repo"
    render_readme "$repo" > "$readme"
    render_manifest "$repo" > "$manifest"
    echo "  -> rewrote README.md"
    echo "  -> rewrote repo-manifest.yaml"
  fi

  if [[ "$MODE" == "classify" ]]; then
    if [ -f "$manifest" ]; then
      classify_repo "$repo"
      set_yaml_scalar_if_unknown "$manifest" "family" "$ENGINE_FAMILY"
      set_yaml_scalar_if_unknown "$manifest" "class" "$ENGINE_CLASS"
      set_yaml_scalar_if_unknown "$manifest" "role" "$ENGINE_ROLE"
      set_yaml_scalar_if_unknown "$manifest" "layer" "$IDENTITY_LAYER"
    fi
  fi

  if [[ "$MODE" == "topology" ]]; then
    if [ -f "$manifest" ]; then
      classify_repo "$repo"
      set_depends_if_empty "$manifest" "${DEPENDS_ON[@]}"
    fi
  fi

  if [[ "$MODE" == "doctor" ]]; then
    if [ -f "$manifest" ]; then
      if doctor_manifest "$repo" "$manifest"; then
        echo "  Doctor: OK"
      else
        echo "  Doctor: ATTENTION"
      fi
    else
      echo "  Doctor: ATTENTION"
    fi
  fi

  if [[ "$MODE" == "enforce" || "$MODE" == "enforce-manifest" ]]; then
    classify_repo "$repo"
    render_manifest "$repo" > "$manifest"
    echo "  -> enforced repo-manifest.yaml"
  fi

  if [[ "$MODE" == "enforce" || "$MODE" == "enforce-readme" ]]; then
    classify_repo "$repo"
    render_readme "$repo" > "$readme"
    echo "  -> enforced README.md"
  fi

  if [[ $readme_ok -eq 1 && $manifest_ok -eq 1 ]]; then
    echo "  Canon: OK"
  else
    echo "  Canon: CHECK"
  fi

  echo
done
