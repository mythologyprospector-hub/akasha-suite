# =============================
# Akasha ecosystem gitignore
# =============================

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# build artifacts
build/
dist/

# local debug
*.log
*.tmp

# backups created by patchers
*.bak
*.bak.*

# discovery artifacts
tree.txt
output.txt

# OS junk
.DS_Store
Thumbs.db

# editor junk
*.swp
*.swo

# ==================================
# AKASHA_CANON_GUARD
# Protect canonical files
# ==================================
!/README.md
!/repo-manifest.yaml

# ==================================
# AKASHA_NOISE_FILTER
# Generated artifacts
# ==================================
ARCHETYPE_COVERAGE_MAP.md
*.log
*.tmp
*.cache
.DS_Store

# Discovery engine artifacts
tree.txt
output.txt
*_run_output.txt

